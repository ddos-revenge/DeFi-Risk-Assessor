# Web portal runtime
WEB_PORTAL_SECRET_KEY=change-this-in-production
WEB_PORTAL_HOST=127.0.0.1
WEB_PORTAL_PORT=5050
WEB_PORTAL_FORCE_HTTPS=false
# When Nginx/Cloudflare terminates TLS and the app listens on HTTP locally, set this true so HSTS + Secure cookies still apply (use with trusted X-Forwarded-Proto).
WEB_PORTAL_EDGE_TLS_TERMINATION=false
WEB_PORTAL_ALLOWED_ORIGINS=https://app.example.com
WEB_PORTAL_PUBLIC_BASE_URL=https://app.hodler-suite.com
WEB_PORTAL_APP_BASE_URL=https://app.hodler-suite.com
WEB_PORTAL_MARKETING_BASE_URL=https://hodler-suite.com
# Optional explicit cookie domain for cross-subdomain login sessions (for example: .hodler-suite.com)
# Leave empty to auto-derive when APP and MARKETING hosts are compatible.
WEB_PORTAL_SESSION_COOKIE_DOMAIN=
# Session cookie name used by the web portal. Keep default unless you have a compatibility reason.
WEB_PORTAL_SESSION_COOKIE_NAME=hs_portal_session
# Optional explicit logo URL used in HTML emails (defaults to WEB_PORTAL_PUBLIC_BASE_URL + /static/brand/hodler-suite-email-logo.png)
EMAIL_BRAND_LOGO_URL=
WEB_PORTAL_AUTH_DB=/opt/hodler-suite/web_portal/data/web_portal_auth.db
# Encrypted API key vault (PBKDF2 + Fernet). Default path is alongside the auth DB unless overridden.
# CREDENTIALS_VAULT_PATH=/opt/hodler-suite/web_portal/data/credentials_vault.enc
# Master password: must match the vault you edit in Settings → Credentials.
# Production: set VAULT_MASTER_PASSWORD in the systemd EnvironmentFile for hodler-web-portal (often
# /etc/hodler-suite/web_portal.env). Without it, the web process cannot decrypt the vault and API
# Center probes / "Configured" badges will miss vault-only keys (risk-worker parity).
# VAULT_MASTER_PASSWORD=
# Optional overrides for Services Status → Chains Status RPC probes (defaults use public endpoints).
# STATUS_ETH_RPC_URL=  STATUS_POLYGON_RPC_URL=  STATUS_SOLANA_RPC_URL=  etc.
WEB_PORTAL_SUPPORT_DB=/opt/hodler-suite/web_portal/data/support_tickets.db
WEB_PORTAL_BILLING_DB=/opt/hodler-suite/web_portal/data/billing.db
WEB_PORTAL_STATUS_DB=/opt/hodler-suite/web_portal/data/status_metrics.db
WEB_PORTAL_RISK_JOB_DB=/opt/hodler-suite/web_portal/data/risk_jobs.db
WEB_PORTAL_TOKEN_LIST_DB=/opt/hodler-suite/web_portal/data/token_lists.db
# Optional: operator outbound email templates (Support / marketing slice); defaults to data/marketing_outreach.db
WEB_PORTAL_MARKETING_OUTREACH_DB=
# Marketing send abuse controls. Keep these conservative until explicit campaign consent is tracked.
MARKETING_SEND_MAX_RECIPIENTS_PER_REQUEST=50
MARKETING_SEND_ACTOR_PER_HOUR=100
MARKETING_SEND_RECIPIENT_PER_DAY=2
# Optional separate HMAC secret for one-click unsubscribe links. If empty, a strong WEB_PORTAL_SECRET_KEY is used.
MARKETING_UNSUBSCRIBE_SECRET=
AUTH_2FA_ISSUER=Hodler Suite
MASTER_ACCOUNT_EMAIL=admin@hodler-suite.com
MASTER_ACCOUNT_PASSWORD=change-master-password-now
SESSION_IDLE_MINUTES=720
# Production: require 2FA for sensitive master/admin actions (recommended true).
SENSITIVE_OPS_REQUIRE_2FA=false
AUTH_ANOMALY_PROMPT_ENABLED=true
AUTH_FAILED_LOGIN_WINDOW_MINUTES=15
AUTH_FAILED_LOGIN_MAX_ATTEMPTS=6
AUTH_FAILED_LOGIN_LOCKOUT_MINUTES=15
# Example (IP2Location Security API): https://api.ip2location.io/?key={api_key}&ip={ip}&format=json
IP_INTEL_LOOKUP_URL=
IP_INTEL_API_KEY=
IP_INTEL_TIMEOUT_SECONDS=4
IP_INTEL_CACHE_TTL_SECONDS=300
USER_OPERATION_RETENTION_DAYS=180
USER_DEVICE_RETENTION_DAYS=180
USER_LOGIN_CONTEXT_RETENTION_DAYS=90
BLACKLIST_ACTION_RETENTION_DAYS=365
API_AUDIT_HISTORY_RETENTION_DAYS=180
# Default minimum seconds between API Center "Probe Now" runs when a service has no registry/policy
# timing (merged with per-endpoint ``rate_limit``/``rate_period`` from ``api_services_registry.json``,
# optional ``api_rate_limits_free_tier.json``, and scanner ``cooldown_until``).
API_CENTER_PROBE_COOLDOWN_SECONDS=120
# ChainAbuse standard API keys are 10 calls/month; set "partner" only after ChainAbuse approves it.
CHAINABUSE_RATE_LIMIT_TIER=standard
# Shared ChainAbuse cache/queue DB. Defaults to API runtime dir when empty.
HODLER_CHAINABUSE_CACHE_DB=
# Normal risk runs read cache + enqueue misses. Enable direct calls only for approved partner/enterprise keys.
HODLER_CHAINABUSE_DIRECT_ENABLED=false
# API Center ChainAbuse probes are local by default so they do not consume the 10/month standard quota.
CHAINABUSE_LIVE_PROBE_ENABLED=false
# After a ChainAbuse probe sees HTTP 429 without Retry-After, assume the monthly bucket is exhausted.
CHAINABUSE_PROBE_COOLDOWN_AFTER_429=2592000
API_PROBE_COOLDOWN_AFTER_429=120
USER_TELEMETRY_PURGE_ON_STARTUP=true
USER_TELEMETRY_RETENTION_ENABLED=true
USER_TELEMETRY_PURGE_DRY_RUN=false

# Billing adapter
NOWPAYMENTS_ENABLED=false
NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Reject IPN if updated_at/created_at is older than this many seconds (default 7d). Set 0 to disable.
NOWPAYMENTS_WEBHOOK_MAX_EVENT_AGE_SECONDS=604800
NOWPAYMENTS_SUCCESS_URL=https://app.example.com/checkout/payment/success
NOWPAYMENTS_CANCEL_URL=https://app.example.com/checkout/payment/failed
NOWPAYMENTS_PARTIAL_URL=https://app.example.com/checkout/payment/partial
NOWPAYMENTS_DONATION_WIDGET_URL=
NOWPAYMENTS_DONATION_LINK_URL=
# Homepage footer social links (optional). X defaults to Degens_HODL; leave LinkedIn/Telegram empty until URLs exist.
HOMEPAGE_SOCIAL_X_URL=https://x.com/Degens_HODL
HOMEPAGE_SOCIAL_LINKEDIN_URL=
HOMEPAGE_SOCIAL_TELEGRAM_URL=
PUBLIC_DOCS_URL=https://docs.hodler-suite.com

# De.Fi GraphQL (https://docs.de.fi/api/api) — header: X-Api-Key
DEFI_API_KEY=
DEFI_GRAPHQL_URL=https://public-api.de.fi/graphql
NOWPAYMENTS_PLAN_CATALOG={"basic-monthly":49.99,"pro-monthly":299.99}
NOWPAYMENTS_PAY_CURRENCIES=[{"code":"usdttrc20","label":"USDT (TRC-20)"},{"code":"usdc","label":"USDC (ERC-20)"}]
SCRIPT_API_HEALTH_URL=http://127.0.0.1:5001/webhook/health
# Deep probes: optional per-chain overrides. If unset, Services Status uses
#   ${SCRIPT_API_HEALTH_URL}/deep/<chain>  (see app/hodler_chain_codes.py SCRIPT_API_DEEP_PROBE_SPECS).
# Path segment = canonical chain (eth|bsc|tron|polygon|op|arbitrum|base|mantle|linea|sei|avax|zksync|solana|thorchain)
SCRIPT_API_ETH_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/eth
SCRIPT_API_BSC_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/bsc
SCRIPT_API_TRON_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/tron
SCRIPT_API_POLYGON_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/polygon
SCRIPT_API_OP_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/op
SCRIPT_API_ARBITRUM_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/arbitrum
SCRIPT_API_BASE_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/base
SCRIPT_API_MANTLE_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/mantle
SCRIPT_API_LINEA_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/linea
SCRIPT_API_SEI_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/sei
SCRIPT_API_AVAX_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/avax
SCRIPT_API_ZKSYNC_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/zksync
SCRIPT_API_SOLANA_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/solana
SCRIPT_API_THORCHAIN_HEALTH_URL=http://127.0.0.1:5001/webhook/health/deep/thorchain
# Optional auth/signing for private Script API probe endpoints.
# Falls back to WEBHOOK_SHARED_SECRET when SCRIPT_API_PROBE_SHARED_SECRET is empty.
# Only enable for trusted first-party probe URLs.
SCRIPT_API_PROBE_SHARED_SECRET=
SCRIPT_API_PROBE_SIGNED=true
# Status-probe alert thresholds (used for operational alert generation on Script API/chain probes).
STATUS_PROBE_WINDOW_HOURS=6
STATUS_PROBE_MIN_SAMPLES=6
STATUS_PROBE_FAILURE_STREAK_THRESHOLD=3
STATUS_PROBE_ERROR_RATE_WARNING_PCT=35
STATUS_PROBE_ERROR_RATE_CRITICAL_PCT=60
STATUS_PROBE_LATENCY_WARNING_MS=2500
STATUS_PROBE_LATENCY_CRITICAL_MS=5000
# Risk-runtime status thresholds (Services Status risk cards + alerting)
RISK_STATUS_QUEUE_WARN=10
RISK_STATUS_QUEUE_CRITICAL=40
RISK_STATUS_QUEUE_STALL_MINUTES=10
RISK_STATUS_STALE_RUNNING_MINUTES=20
RISK_STATUS_WINDOW_HOURS=24
RISK_STATUS_FAILURE_RATE_WARNING_PCT=25
RISK_STATUS_FAILURE_RATE_CRITICAL_PCT=50
RISK_STATUS_FAILURE_RATE_MIN_COMPLETED=4
STATUS_PUBLIC_EDGE_TIMEOUT_SECONDS=6
STATUS_NGINX_LOCAL_URL=http://127.0.0.1/healthz
STATUS_NGINX_LOCAL_TIMEOUT_SECONDS=3
STATUS_TLS_TIMEOUT_SECONDS=4
# Atlassian API token renewal reminder (Services Status -> Infrastructure card)
# Format: YYYY-MM-DD (UTC)
ATLASSIAN_API_TOKEN_EXPIRES_ON=
ATLASSIAN_API_TOKEN_RENEW_WARNING_DAYS=45
ATLASSIAN_API_TOKEN_RENEW_CRITICAL_DAYS=14
STATUS_DISK_FREE_WARNING_PCT=15
STATUS_DISK_FREE_CRITICAL_PCT=8
# Optional: mount path for disk charts on Services Status → Host control panel (default /)
HOST_METRICS_DISK_PATH=/
STATUS_DB_SIZE_WARNING_MB=1024
STATUS_DB_SIZE_CRITICAL_MB=4096

# AI support triage (scaffold only)
SUPPORT_TRIAGE_PROVIDER=disabled
SUPPORT_TRIAGE_API_KEY=
SUPPORT_TRIAGE_WEBHOOK_URL=
SUPPORT_TRIAGE_WEBHOOK_SECRET=

# UVdesk (https://github.com/uvdesk/community-skeleton) — optional API bridge to self-hosted helpdesk
UVDESK_ENABLED=false
UVDESK_BASE_URL=
# API token from UVdesk admin; can also be stored in the encrypted credentials vault as UVDESK_API_TOKEN
UVDESK_API_TOKEN=

# Support ticket email delivery
SUPPORT_SMTP_HOST=
SUPPORT_SMTP_PORT=587
SUPPORT_SMTP_USERNAME=
SUPPORT_SMTP_PASSWORD=
SUPPORT_SMTP_USE_TLS=true
SUPPORT_SMTP_USE_SSL=false
ACCOUNT_EMAIL_FROM=no_reply@hodler-suite.com
ACCOUNT_EMAIL_SUBJECT_PREFIX=[Hodler Suite]
SUPPORT_EMAIL_FROM=support@hodler-suite.com
MARKETING_EMAIL_FROM=marketing@hodler-suite.com
SUPPORT_EMAIL_NOTIFY_TO=support@hodler-suite.com
SUPPORT_EMAIL_SUBJECT_PREFIX=[Hodler Suite]
SUPPORT_INBOUND_REPLY_TO=tickets@inbound.hodler-suite.com
SUPPORT_INBOUND_ROUTING_ACTIVE=false
SUPPORT_AGENT_EMAILS=support@hodler-suite.com,admin@hodler-suite.com
SUPPORT_INBOUND_WEBHOOK_SECRET=change-this-secret
# SUPPORT_RESEND_API_KEY can also come from the encrypted credentials vault.
SUPPORT_RESEND_API_KEY=
# Set false only if you rely on webhooks alone and do not use GET /emails/receiving (avoids list API + alerts).
SUPPORT_RESEND_RECEIVING_SYNC_ENABLED=true
SUPPORT_RESEND_FETCH_TIMEOUT_SECONDS=15
SUPPORT_TICKET_ATTACHMENTS_DIR=/opt/hodler-suite/web_portal/data/support_attachments
SUPPORT_TICKET_ATTACHMENT_MAX_FILES=5
SUPPORT_TICKET_ATTACHMENT_MAX_BYTES=26214400
SUPPORT_TICKET_ATTACHMENT_SCAN_CLAMAV=true
STATUS_SAMPLER_SECRET=
STATUS_SAMPLER_BASE_URL=http://127.0.0.1:5050
STATUS_SAMPLER_TIMEOUT_SECONDS=20
STATUS_SAMPLER_WAIT_FOR_APP_SECONDS=20
STATUS_SAMPLER_HTTP_ATTEMPTS=3
# Slack #status_changes — service good↔bad transitions + host CPU/RAM/disk/disk-I/O (wired from internal status-sample).
STATUS_CHANGES_SLACK_ENABLED=false
# When true (default), new Support operational alerts are also posted to the same webhook as service transitions.
STATUS_CHANGES_SLACK_OPERATIONAL_ALERTS=true
STATUS_CHANGES_SLACK_WEBHOOK_URL=
STATUS_CHANGES_SLACK_TIMEOUT_SECONDS=8
# Optional: JSON state file (default web_portal/data/status_changes_state.json)
STATUS_CHANGES_STATE_PATH=
STATUS_CHANGES_CPU_PERCENT=90
STATUS_CHANGES_RAM_PERCENT=90
STATUS_CHANGES_DISK_FREE_GB=5
# Aggregate read+write throughput (MB/s) vs previous sample; 0 disables this arm
STATUS_CHANGES_DISK_IO_MBYTES_PER_SEC=20
# Linux iowait % from psutil; 0 disables this arm
STATUS_CHANGES_IOWAIT_PERCENT=25
SCRIPT_API_WATCHDOG_URL=http://127.0.0.1:5001/webhook/health
SCRIPT_API_WATCHDOG_TIMEOUT_SECONDS=6
SCRIPT_API_WATCHDOG_FAILURE_THRESHOLD=3
SCRIPT_API_WATCHDOG_HTTP_ATTEMPTS=3
SCRIPT_API_WATCHDOG_RETRY_DELAY_SECONDS=2
SCRIPT_API_WATCHDOG_UNIT=hodler-script-api.service
SCRIPT_API_WATCHDOG_STATE_FILE=/var/lib/hodler-suite/script_api_watchdog.state
RISK_WORKER_SHARED_SECRET=
# Optional: append stderr from risk_worker_process.py (engine import/runtime) for debugging stuck jobs.
# RISK_WORKER_SUBPROCESS_STDERR_LOG=/var/log/hodler-suite/risk_worker_subprocess.log
# Optional: set to 1 to disable fork supervisor (single-process worker; Linux/macOS default uses supervisor).
# HODLER_RISK_WORKER_NO_FORK=1
RISK_COMPAT_SHARED_SECRET=
# Additional additive score penalty when a wrapped-token red flag is detected (0-20).
WRAPPED_TOKEN_RISK_PENALTY=8.0
RISK_WORKER_BASE_URL=http://127.0.0.1:5050
RISK_WORKER_TIMEOUT_SECONDS=40
RISK_WORKER_WAIT_FOR_APP_SECONDS=20
RISK_WORKER_ID=
SUPPORT_RESEND_SYNC_BASE_URL=http://127.0.0.1:5050
SUPPORT_RESEND_SYNC_LIMIT=50
# Warning threshold for orphan inbound replies (ticket reference not found) during fallback sync.
SUPPORT_RESEND_SYNC_UNMAPPED_ALERT_THRESHOLD=5
# Number of consecutive over-threshold runs required to mark unmapped traffic as sustained.
SUPPORT_RESEND_SYNC_UNMAPPED_SUSTAINED_RUNS=3
SUPPORT_SLACK_ENABLED=false
SUPPORT_SLACK_WEBHOOK_URL=
SUPPORT_SLACK_TIMEOUT_SECONDS=8
# Bug Report -> @Cursor automation
SUPPORT_BUG_CURSOR_ENABLED=false
# Modes: webhook | chat_post_message
SUPPORT_BUG_CURSOR_POST_MODE=webhook
# Used in webhook mode:
SUPPORT_BUG_CURSOR_WEBHOOK_URL=
# Used in chat_post_message mode (recommended for Cursor triggers):
# Token should have Slack scopes for both message + file upload relay (e.g. chat:write, files:write).
SUPPORT_BUG_CURSOR_USER_TOKEN=
SUPPORT_BUG_CURSOR_CHANNEL_ID=
# Prefer a direct Slack mention token (<@UXXXXXXXX>) to guarantee app/user tagging.
# Plain labels like @Cursor are now auto-resolved when possible from Slack APIs.
SUPPORT_BUG_CURSOR_MENTION=@Cursor
SUPPORT_BUG_CURSOR_TIMEOUT_SECONDS=8
# Optional: delegate Bug Report dispatch to existing RPA sender script instead of Slack API post.
SUPPORT_BUG_CURSOR_RPA_ENABLED=false
SUPPORT_BUG_CURSOR_RPA_SCRIPT=/opt/hodler-suite/rpa/send_cursor_bug_report.py
SUPPORT_BUG_CURSOR_RPA_PYTHON=/opt/hodler-suite/rpa/.venv/bin/python
SUPPORT_BUG_CURSOR_RPA_ENV_FILE=/etc/default/hodler-slack-rpa
SUPPORT_BUG_CURSOR_RPA_TIMEOUT_SECONDS=40
# RPA sender delivery mode: ui | chat_post_message | webhook
SUPPORT_BUG_CURSOR_SEND_MODE=ui
# Persistent X11 session settings (used by UI mode sender + slack-ui-session service)
SUPPORT_BUG_CURSOR_UI_DISPLAY=:1
SUPPORT_BUG_CURSOR_UI_SCREEN=1920x1080x24
SUPPORT_BUG_CURSOR_UI_BOOT_WAIT_SECONDS=20
SUPPORT_BUG_CURSOR_UI_WINDOW_PATTERN=Slack|Chromium|Chrome|Mozilla Firefox
SUPPORT_BUG_CURSOR_UI_BROWSER_CMD=chromium-browser --new-window
SUPPORT_BUG_CURSOR_UI_CHANNEL_URL=https://app.slack.com/client/T0AHT027B4H/C0AKDAF9J6L
SUPPORT_BUG_CURSOR_VNC_PORT=5901
SUPPORT_BUG_CURSOR_NOVNC_PORT=6080
# Slack Events + GitHub PR approval automation on ✅ reactions
SLACK_EVENTS_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_GITHUB_PULL_REQUESTS_CHANNEL_ID=
SLACK_GITHUB_APPROVER_USER_IDS=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_SLACK_AUTO_MERGE=false
GITHUB_SLACK_MERGE_METHOD=squash
# Weekly / monthly Slack digest (#periodic_reports) — tools/weekly_periodic_report.py + systemd timers
PERIODIC_REPORTS_SLACK_WEBHOOK_URL=
# Daily website usage & subscription counters (#website_statistics) — tools/website_statistics_daily_report.py
WEBSITE_STATISTICS_SLACK_WEBHOOK_URL=
# Optional: dedicated SQLite for consent-scoped visit aggregates (default: web_portal/data/usage_statistics.db)
WEB_PORTAL_USAGE_STATISTICS_DB=
# Optional: non-default cscli binary path for CrowdSec stats on the report host
CROWDSEC_CSCLI_PATH=
TRUSTPILOT_WEBHOOK_SECRET=
TRUSTPILOT_SLACK_ENABLED=false
TRUSTPILOT_SLACK_WEBHOOK_URL=
TRUSTPILOT_SLACK_TIMEOUT_SECONDS=8
# Trustpilot SAF: BCC on plan booking confirmation emails only (not auth/security mail).
TRUSTPILOT_SAF_BCC=
# Twitter/X webhooks read TWITTER_API_SECRET from the encrypted credentials vault
# for CRC/signature validation when VAULT_MASTER_PASSWORD is configured.
# Optional env overrides: X_WEBHOOK_SECRET, X_WEBHOOK_CRC_CONSUMER_SECRET,
# X_PROFILE_USERNAME, X_PROFILE_USER_ID.
X_SLACK_ENABLED=false
X_SLACK_WEBHOOK_URL=
X_SLACK_TIMEOUT_SECONDS=8
SUPPORT_RATE_LIMIT_IP_PER_5M=6
SUPPORT_RATE_LIMIT_EMAIL_PER_5M=3
SUPPORT_RATE_LIMIT_IP_PER_HOUR=30
SUPPORT_RATE_LIMIT_EMAIL_PER_HOUR=10
ACCOUNT_SECURITY_CODE_EXPIRY_MINUTES=30
ACCOUNT_SECURITY_CODE_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_EXPIRY_MINUTES=30
SIGNUP_CODE_EXPIRY_MINUTES=30
SIGNUP_CODE_RESEND_COOLDOWN_SECONDS=60
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Leave empty to auto-enable when both keys are configured.
TURNSTILE_ENFORCE=
# Optional post-Turnstile browser integrity gate. Detects common ad/script blockers with same-origin checks only.
ADBLOCK_GATE_ENABLED=false
